# [CLIENT NAME] — Environment Overlay
# Copy this to .env on client's machine and fill in real values.
# Never commit real credentials.

# -----------------------------------------------------------------------
# Email — Inbound PO polling
# -----------------------------------------------------------------------
EMAIL_HOST=TODO_imap_server
EMAIL_USER=TODO_email_address
EMAIL_PASSWORD=TODO_password_or_app_password
EMAIL_IMAP_PORT=993

EMAIL_SMTP_HOST=TODO_smtp_server
EMAIL_SMTP_PORT=587

# -----------------------------------------------------------------------
# A2000 / POS Integration
# -----------------------------------------------------------------------
# Start with mock. Upgrade once POS integration is confirmed.
A2000_MODE=mock

# EDI mode
EDI_OUTPUT_DIR=TODO_path_to_edi_pickup_folder
EDI_SENDER_ID=TODO_sender_id
EDI_RECEIVER_ID=TODO_receiver_id

# API mode
A2000_API_URL=TODO_api_url
A2000_API_KEY=TODO_api_key

# Playwright mode
A2000_BROWSER_URL=TODO_browser_url_or_app_path
A2000_BROWSER_USER=TODO_pos_login_user
A2000_BROWSER_PASS=TODO_pos_login_password

# -----------------------------------------------------------------------
# LLM — Ollama (local, on client hardware)
# -----------------------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:32b

# -----------------------------------------------------------------------
# Storage and Logging
# -----------------------------------------------------------------------
DB_PATH=./storage/client.db
LOG_DIR=./logs
LOG_LEVEL=INFO

# -----------------------------------------------------------------------
# Escalation
# -----------------------------------------------------------------------
ESCALATION_EMAIL=TODO_operator_alert_email

# -----------------------------------------------------------------------
# Identity
# -----------------------------------------------------------------------
COMPANY_NAME=TODO_client_company_name
