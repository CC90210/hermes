# Lowinger Distribution — Environment Overlay
# Copy this to .env on Emmanuel's machine and fill in real values.
# Never commit real credentials.

# -----------------------------------------------------------------------
# Email — Outlook / Microsoft 365
# -----------------------------------------------------------------------
EMAIL_HOST=outlook.office365.com
EMAIL_USER=TODO_emmanuels_outlook_address@lowinger.com
EMAIL_PASSWORD=TODO_app_specific_password_from_ms365_security_settings
EMAIL_IMAP_PORT=993

EMAIL_SMTP_HOST=smtp.office365.com
EMAIL_SMTP_PORT=587

# -----------------------------------------------------------------------
# A2000 POS Integration
# -----------------------------------------------------------------------
# Start here. Switch to 'edi' or 'api' once confirmed with GCS.
A2000_MODE=mock

# EDI mode (switch when A2000 EDI module is confirmed active)
EDI_OUTPUT_DIR=TODO_path_to_a2000_edi_pickup_folder
EDI_SENDER_ID=LOWINGER
EDI_RECEIVER_ID=A2000

# API mode (only if GCS Software provides REST credentials)
A2000_API_URL=TODO_gcs_api_url
A2000_API_KEY=TODO_gcs_api_key

# -----------------------------------------------------------------------
# LLM — Ollama (must be installed on Emmanuel's machine)
# -----------------------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:32b

# -----------------------------------------------------------------------
# Storage and Logging
# -----------------------------------------------------------------------
DB_PATH=./storage/lowinger.db
LOG_DIR=./logs
LOG_LEVEL=INFO

# -----------------------------------------------------------------------
# Escalation
# -----------------------------------------------------------------------
# Hermes sends alerts here when orders fail after 3 retries.
ESCALATION_EMAIL=TODO_emmanuel_email_for_alerts

# -----------------------------------------------------------------------
# Identity
# -----------------------------------------------------------------------
COMPANY_NAME=Lowinger Distribution

# -----------------------------------------------------------------------
# Printing (Phase 2c — optional, requires Windows + pywin32)
# -----------------------------------------------------------------------
# Set to 1 to auto-print a warehouse PO copy after every successful order entry
HERMES_PRINT_WAREHOUSE_PO=0
# Set to 1 to auto-print GS1-128 carton labels on shipment
HERMES_PRINT_LABELS=0
# Exact printer name for warehouse PO (leave blank to use system default)
# Run: python scripts/printer_tool.py --list  to find the correct name
WAREHOUSE_PRINTER_NAME=
# Exact name of the Zebra / thermal printer for GS1-128 labels (required if HERMES_PRINT_LABELS=1)
LABEL_PRINTER_NAME=

# -----------------------------------------------------------------------
# Desktop notifications
# -----------------------------------------------------------------------
# Set to 0 to suppress all desktop notifications
HERMES_DESKTOP_NOTIFICATIONS=1

# -----------------------------------------------------------------------
# Folder watcher (fallback if IMAP is blocked)
# -----------------------------------------------------------------------
# Absolute path to a folder where PO files are manually dropped (optional)
# Hermes will detect new .pdf/.xlsx files and trigger the normal PO pipeline
HERMES_PO_DROP_FOLDER=
