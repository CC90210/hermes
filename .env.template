# Hermes — Environment Configuration
# Copy to .env and fill in real values. NEVER commit .env

# PO parser routing
# auto             — try Ollama first, fall back to Anthropic then OpenAI
# ollama-local     — local only, no fallback (best privacy, requires running Ollama)
# cloud-anthropic  — Anthropic Claude only (requires ANTHROPIC_API_KEY)
# cloud-openai     — OpenAI only (requires OPENAI_API_KEY)
HERMES_PO_PARSER=ollama-local

# Ollama (local model — used by PO parser when HERMES_PO_PARSER=ollama-local or auto)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:32b

# Cloud parser fallback (used when HERMES_PO_PARSER=cloud-* or auto and Ollama fails)
# Both providers operate under no-storage / no-training Data Processing Agreements.
ANTHROPIC_API_KEY=
HERMES_ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
HERMES_OPENAI_MODEL=gpt-4.1-mini

# Email (Outlook/Exchange)
EMAIL_HOST=outlook.office365.com
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=smtp.office365.com
EMAIL_SMTP_PORT=587

# Escalation (alert emails sent to this address)
ESCALATION_EMAIL=emmanuel@lowinger.com

# A2000 POS
A2000_API_URL=
A2000_API_KEY=
A2000_MODE=mock  # mock | api | edi | playwright | desktop

# Storage
DB_PATH=./storage/lowinger.db

# Invoice / Email
COMPANY_NAME=Lowinger Distribution

# EDI output (used when A2000_MODE=edi)
EDI_OUTPUT_DIR=./storage/edi_out
EDI_SENDER_ID=LOWINGER
EDI_RECEIVER_ID=A2000

# Playwright fallback (used when A2000_MODE=playwright — for web/Electron ERPs)
A2000_BROWSER_URL=
A2000_BROWSER_USER=
A2000_BROWSER_PASS=

# Desktop automation (used when A2000_MODE=desktop — native Win32 ERPs like GCS A2000)
# Requires pywinauto (Windows only). See docs/PREFLIGHT.md for full setup.
A2000_EXECUTABLE_PATH=
A2000_WINDOW_TITLE=
A2000_DESKTOP_USER=
A2000_DESKTOP_PASS=
A2000_RECIPE_PATH=./storage/a2000_recipe.json
A2000_SCREENSHOT_DIR=./storage/a2000_screenshots
# Hard safety gate — must be set to 1 before the desktop adapter will click anything
HERMES_DESKTOP_AUTOMATION_ARMED=0
# Lock file that prevents two Hermes processes (cron + IDE) from driving A2000
# at the same time. The desktop adapter creates this with O_EXCL on entry and
# removes it on exit. If you ever see "lock held by another process" and you
# are sure no Hermes is running, delete this file manually.
A2000_LOCK_FILE=./storage/a2000_desktop.lock

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# ---------------------------------------------------------------------------
# Printing (Phase 2c — optional, requires Windows + pywin32)
# ---------------------------------------------------------------------------
# Set to 1 to auto-print a warehouse PO copy after every successful order entry
HERMES_PRINT_WAREHOUSE_PO=0
# Set to 1 to auto-print GS1-128 carton labels on shipment
HERMES_PRINT_LABELS=0
# Exact printer name for warehouse PO (leave blank to use system default)
# Run: python scripts/printer_tool.py --list  to find the correct name
WAREHOUSE_PRINTER_NAME=
# Exact name of the Zebra / thermal printer for GS1-128 labels (required if HERMES_PRINT_LABELS=1)
LABEL_PRINTER_NAME=

# ---------------------------------------------------------------------------
# Desktop notifications
# ---------------------------------------------------------------------------
# Set to 0 to suppress all desktop notifications
HERMES_DESKTOP_NOTIFICATIONS=1

# ---------------------------------------------------------------------------
# Folder watcher (fallback if IMAP is blocked)
# ---------------------------------------------------------------------------
# Absolute path to a folder where PO files are manually dropped (optional)
# Hermes will detect new .pdf/.xlsx files and trigger the normal PO pipeline
HERMES_PO_DROP_FOLDER=
